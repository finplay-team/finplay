# 필요한 환경변수 목록. 실제 값은 .env(gitignore됨)에 복사해 채우거나 셸/CI 시크릿으로 주입한다.
# 이 파일에는 절대 실제 값을 적지 않는다 (conventions.md 시크릿 규칙).

# --- 인증 (PRD 태스크 2에서 사용) ---
# 32바이트 이상 랜덤 문자열. 생성 예: openssl rand -base64 48
# 로컬 포함 모든 환경에서 환경변수로만 주입한다 — yml에 기본값을 두지 않는다 (튜터 피드백 2026-07-24).
JWT_SECRET=

# 카카오/네이버 OAuth. 실키가 없으면 Fake OAuth 프로필로 실행한다 (PRD AUTH-003).
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 이메일 인증 (PRD AUTH-004) ---
# 인증번호 HMAC-SHA-256용. 32바이트 이상 랜덤. JWT_SECRET과 반드시 다른 값을 쓴다.
# 로컬·테스트에서도 인증번호 저장에 쓰이므로 채워두는 것을 권장한다.
EMAIL_VERIFICATION_SECRET=

# --- 이메일 발송 (운영 프로필에서만 필요) ---
# 로컬·테스트는 FakeEmailSender를 쓰므로 아래 두 값이 비어 있어도 앱과 테스트가 정상 기동한다.
# Resend에 인증된 발신 서브도메인이 필요하다 (DNS는 팀 Route 53에서 관리 — docs/specs/010-deployment).
RESEND_API_KEY=
EMAIL_FROM=

# --- 배포(prod 프로필)에서만 필요. 로컬은 spring-boot-docker-compose가 자동 구성 ---
DB_URL=
DB_USERNAME=
DB_PASSWORD=
