# 필요한 환경변수 목록. 실제 값은 .env(gitignore됨)에 복사해 채우거나 셸/CI 시크릿으로 주입한다.
# 이 파일에는 절대 실제 값을 적지 않는다 (conventions.md 시크릿 규칙).

# --- 인증 (PRD 태스크 2에서 사용) ---
# 32바이트 이상 랜덤 문자열. 생성 예: openssl rand -base64 48
# 로컬 포함 모든 환경에서 환경변수로만 주입한다 — yml에 기본값을 두지 않는다 (튜터 피드백 2026-07-24).
JWT_SECRET=

# 카카오/네이버 OAuth. 실키가 없으면 Fake OAuth 프로필로 실행한다 (PRD AUTH-003).
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 이메일 인증 (PRD AUTH-004) ---
# 인증번호 HMAC-SHA-256용. 32바이트 이상 랜덤. JWT_SECRET과 반드시 다른 값을 쓴다.
# 로컬·테스트에서도 인증번호 저장에 쓰이므로 채워두는 것을 권장한다.
EMAIL_VERIFICATION_SECRET=

# --- 이메일 발송 (운영 프로필에서만 필요) ---
# 로컬·테스트는 FakeEmailSender를 쓰므로 아래 두 값이 비어 있어도 앱과 테스트가 정상 기동한다.
# Resend에 인증된 발신 서브도메인이 필요하다 (DNS는 팀 Route 53에서 관리 — docs/specs/010-deployment).
RESEND_API_KEY=
EMAIL_FROM=

# --- 주식 시세 공급자 (PRD C-007 / MKT-007) ---
# KIS_REALTIME = 한국투자 KIS Open API 실시간 체결가 (개인 개발·본인 전용 검증 전용)
# KRX_REPLAY   = KRX 과거 실제 1분봉 재생 (공개 배포 기본값)
STOCK_FEED_PROVIDER=KRX_REPLAY
# PRIVATE = 개발자 본인만 접근하는 로컬·접근 통제 환경 (로그인 필요 서비스라는 뜻이 아니다)
# PUBLIC  = 본인 외 누구든 접근하는 환경. 팀원·튜터·심사위원 시연도 PUBLIC이며 KRX_REPLAY를 쓴다.
# PRIVATE+KIS_REALTIME 환경을 공개 URL이나 다중 사용자 서버로 운영하지 않는다.
SERVICE_EXPOSURE=PRIVATE
# 공개 환경에서 KIS 실시간 표출이 한국투자증권 서면 허가·계약으로 확인된 경우에만 true.
# 이 값을 true로 바꾼다고 허가가 생기지 않는다 — 정본은 서면 답변이며 현재 받은 적 없다.
# PUBLIC + KIS_REALTIME + false 조합은 애플리케이션이 시작 단계에서 실패한다.
KIS_PUBLIC_DISPLAY_APPROVED=false

# --- 한국투자 KIS Open API (STOCK_FEED_PROVIDER=KIS_REALTIME일 때만 필요) ---
# KRX_REPLAY 환경에서는 아래 4개가 비어 있어도 앱과 테스트가 정상 실행된다.
# 실제 값은 서버 환경변수 또는 AWS Secret에만 둔다 — 브라우저·코드·문서·GitHub 금지.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=

# --- 배포(prod 프로필)에서만 필요. 로컬은 spring-boot-docker-compose가 자동 구성 ---
DB_URL=
DB_USERNAME=
DB_PASSWORD=
